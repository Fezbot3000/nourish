rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only touch their own journal.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /days/{day} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
